<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="yEME-gLTZ18guV2mF0eP">
    <mxGraphModel dx="4133" dy="1973" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nhide empty members\n\n&#39; =========================\n&#39; Enums\n&#39; =========================\nenum UserStatus {\n  ACTIVE\n  BLOCKED\n}\n\nenum BookStatus {\n  ACTIVE\n  HIDDEN\n}\n\nenum TransactionStatus {\n  SUCCESS\n  FAILED\n  REFUNDED\n}\n\n&#39; =========================\n&#39; User Management\n&#39; =========================\nabstract class User {\n  - userId: uint64\n  - username: String\n  - passwordHash: String\n  - email: String\n  - status: UserStatus\n  - registrationDate: DateTime\n  --\n  + login(username: String, pass: String): String\n  + resetPassword(newPass: String): void\n}\n\nclass NormalUser {\n  - walletBalance: double\n  - favoriteGenreIds: List&lt;uint64&gt;\n  - personalLibraryId: uint64\n  - activeCartId: uint64\n  --\n  + chargeWallet(amount: double): void\n  + searchBook(keyword: String, genreId: uint64): List&lt;uint64&gt;\n  + purchaseBook(bookId: uint64): bool\n  + writeReview(bookId: uint64, rating: int, comment: String): void\n}\n\nclass Publisher {\n  - publisherName: String\n  - totalIncome: double\n  - ibanNumber: String\n  --\n  + publishBook(bookDetails: Book): void\n  + applyDiscount(bookId: uint64, percentage: float): void\n  + getSalesStatistics(): Map&lt;DateTime, double&gt;\n}\n\nclass Admin {\n  - adminLevel: int\n  --\n  + blockUser(userId: uint64): void\n  + deleteBook(bookId: uint64): void\n  + generateSystemReport(): String\n}\n\nUser &lt;|-- NormalUser\nUser &lt;|-- Publisher\nUser &lt;|-- Admin\n\n&#39; =========================\n&#39; Shop &amp; Content\n&#39; =========================\nclass Book {\n  - bookId: uint64\n  - title: String\n  - authorId: uint64\n  - genreId: uint64\n  - publisherId: uint64\n  - basePrice: double\n  - discountPercentage: float\n  - averageRating: float\n  - pdfFilePath: String\n  - coverImagePath: String\n  - status: BookStatus\n  --\n  + calculateFinalPrice(): double\n  + updateAverageRating(newRating: int): void\n}\n\nclass Author {\n  - authorId: uint64\n  - name: String\n  - biography: String\n}\n\nclass Genre {\n  - genreId: uint64\n  - genreName: String\n}\n\nclass Review {\n  - reviewId: uint64\n  - bookId: uint64\n  - userId: uint64\n  - rating: int\n  - commentText: String\n  - submitDate: DateTime\n  --\n  + editReview(newText: String): void\n}\n\n&#39; =========================\n&#39; Library &amp; Transactions\n&#39; =========================\nclass ShoppingCart {\n  - cartId: uint64\n  - userId: uint64\n  - itemBookIds: List&lt;uint64&gt;\n  - totalPrice: double\n  --\n  + addBook(bookId: uint64): void\n  + removeBook(bookId: uint64): void\n  + checkout(walletBalance: double): bool\n}\n\nclass Transaction {\n  - transactionId: uint64\n  - userId: uint64\n  - bookId: uint64\n  - amountPaid: double\n  - purchaseDate: DateTime\n  - status: TransactionStatus\n  --\n  + generateReceipt(): String\n}\n\nclass Library {\n  - libraryId: uint64\n  - userId: uint64\n  - ownedBookIds: List&lt;uint64&gt;\n  - savedBookIds: List&lt;uint64&gt;\n  - lastReadPositions: Map&lt;uint64, uint32&gt;\n  --\n  + hasBook(bookId: uint64): bool\n  + addPurchasedBook(bookId: uint64): void\n  + updateReadPosition(bookId: uint64, pageNumber: uint32): void\n  + getReadPosition(bookId: uint64): uint32\n}\n\nclass PDFReader {\n  - currentBookId: uint64\n  - currentPage: uint32\n  --\n  + openPdfFile(path: String, startPage: uint32): void\n  + jumpToPage(pageNumber: uint32): void\n}\n\n&#39; =========================\n&#39; Server &amp; System Core\n&#39; =========================\nclass Session {\n  - sessionId: String\n  - userId: uint64\n  - ipAddress: String\n  - loginTime: DateTime\n  - expireAt: DateTime\n  --\n  + isValid(): bool\n  + expireSession(): void\n}\n\nclass Server {\n  - activeThreads: int\n  - maxConnections: int\n  - activeSessions: Map&lt;String, Session&gt;\n  --\n  + handleClientRequest(socket: Socket): void\n  + authenticateRequest(token: String): bool\n}\n\nclass Notification {\n  - notificationId: uint64\n  - userId: uint64\n  - message: String\n  - isRead: bool\n  - timestamp: DateTime\n  --\n  + markAsRead(): void\n}\n\n&#39; =========================\n&#39; Logical Associations (ID-based domain)\n&#39; (Foreign-key style relations)\n&#39; =========================\nNormalUser \&quot;1\&quot; --&gt; \&quot;1\&quot; Library : personalLibraryId\nNormalUser \&quot;1\&quot; --&gt; \&quot;1\&quot; ShoppingCart : activeCartId\n\nPublisher \&quot;1\&quot; --&gt; \&quot;*\&quot; Book : publisherId\nAuthor \&quot;1\&quot; --&gt; \&quot;*\&quot; Book : authorId\nGenre \&quot;1\&quot; --&gt; \&quot;*\&quot; Book : genreId\n\nNormalUser \&quot;1\&quot; --&gt; \&quot;*\&quot; Review : userId\nBook \&quot;1\&quot; --&gt; \&quot;*\&quot; Review : bookId\n\nNormalUser \&quot;1\&quot; --&gt; \&quot;*\&quot; Transaction : userId\nBook \&quot;1\&quot; --&gt; \&quot;*\&quot; Transaction : bookId\n\nUser \&quot;1\&quot; --&gt; \&quot;*\&quot; Session : userId\nUser \&quot;1\&quot; --&gt; \&quot;*\&quot; Notification : userId\n\nLibrary ..&gt; Book : ownedBookIds/savedBookIds\nShoppingCart ..&gt; Book : itemBookIds\nPDFReader ..&gt; Book : currentBookId\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="ODP7_-Ny1AkYufNs8gfA-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1351" width="2571" x="30" y="30" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
